# Copy to .env and adjust if needed. Values below work out-of-the-box with
# the MinIO service from docker-compose.yml.

# --- S3 / MinIO -----------------------------------------------------------
# In a real AWS deployment, these would be issued by IAM (ideally via
# temporary STS credentials, not static keys). For the local demo MinIO
# uses static root creds.
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
# Pointing boto3 at a local S3-compatible endpoint. Unset in real AWS.
AWS_ENDPOINT_URL=http://localhost:9000

# --- Agent identity -------------------------------------------------------
# Logged as the CloudTrail principal for every action the agent takes.
AGENT_NAME=coding-assistant-v1

# --- Exfil sink ----------------------------------------------------------
# The demo's attacker-controlled receiver. The agent will be tricked into
# POSTing data here; the observer watches for this.
EXFIL_ENDPOINT=http://localhost:8888/dump
